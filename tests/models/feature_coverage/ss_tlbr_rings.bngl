# Stress: trivalent-bivalent cross-linking with ring-forming topology
# Tests: incremental bookkeeping with rings and branches simultaneously
# Bug pattern: disjoint+symmetric miscounting + complex expansion (rm_tlbr_rings)
# Tier: stress (network-free; NFsim reference only)
# Target: ~20-40s RM, exercises ring closures within branched aggregates
# invariant: conserved L_total = 80
# invariant: conserved R_total = 120

begin model
begin parameters
    L_tot  80
    R_tot  120
    kf     0.01    # /s, intermolecular binding — strong aggregation
    kr     0.05    # /s, unbinding
end parameters

begin molecule types
    L(r,r,r)
    R(l,l)
end molecule types

begin seed species
    L(r,r,r)  L_tot
    R(l,l)    R_tot
end seed species

begin observables
    Molecules  L_total     L()
    Molecules  R_total     R()
    Molecules  L_free_r    L(r)
    Molecules  R_free_l    R(l)
    Molecules  L_bound     L(r!+)
    Molecules  R_bound     R(l!+)
    Species    Complexes   L(r!+)
end observables

begin reaction rules
    L(r) + R(l) <-> L(r!1).R(l!1)  kf, kr
end reaction rules
end model

begin actions
simulate({method=>"nf",t_end=>400,n_steps=>100,param=>"-bscb -utl 6"})
end actions
