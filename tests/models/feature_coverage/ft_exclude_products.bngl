# Feature: exclude_products(N, pattern) modifier on rules
# Tests: prevents reaction when product N would match the excluded pattern
# Tier: base
# Expected: fast phosphorylation drives all A to p~P. exclude_products blocks
#   binding when product would contain A(p~P). Since phosphorylation doesn't
#   occur during binding, this is functionally equivalent to excluding A(p~P)
#   as reactant. ODE (via BNG2 network expansion) correctly enforces this.
#   NFsim ignores exclude_products in network-free mode.

begin model
begin parameters
    A_tot   100
    B_tot   100
    k_phos  0.5    # /s — fast irreversible phosphorylation (t_half ~ 1.4s)
    kf      0.005  # /(s*molecule) — moderate binding
    kr      0.05   # /s — moderate unbinding (tau ~ 20s)
end parameters

begin molecule types
    A(s,p~U~P)
    B(s)
end molecule types

begin seed species
    A(s,p~U)  A_tot
    B(s)      B_tot
end seed species

begin observables
    Molecules  A_phos     A(p~P)
    Molecules  AB_total   A(s!1).B(s!1)
    Molecules  B_free     B(s)
end observables

begin reaction rules
    # Fast irreversible phosphorylation
    A(p~U) -> A(p~P)  k_phos

    # Binding: blocked if product would contain A(p~P)
    # ODE and RM enforce this; NFsim ignores it
    A(s) + B(s) <-> A(s!1).B(s!1)  kf, kr  exclude_products(1,A(p~P))
end reaction rules
end model

begin actions
simulate({method=>"nf",t_end=>200,n_steps=>50})
end actions
