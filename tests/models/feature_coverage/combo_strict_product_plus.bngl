# Feature combination: strict product-side "+" semantics
# Tests: products separated by "+" must be in different connected components
# Bug pattern: AN/ANx rule splitting bug (773092f)
# Tier: combinations
# Expected: A.B complex splits into separate A + B (not still connected)
# Note: 300 molecules per species to reduce stochastic noise

begin model
begin parameters
    A_tot  300
    B_tot  300
    C_tot  300
    kf1    0.005   # /s, A-B binding (scaled for 300 mols)
    kr1    0.01    # /s, A-B unbinding
    kf2    0.002   # /s, B-C binding
    kr2    0.01    # /s, B-C unbinding
    k_split 0.1   # /s, catalytic splitting of A from A-B-C
end parameters

begin molecule types
    A(b)
    B(a,c)
    C(b)
end molecule types

begin seed species
    A(b)    A_tot
    B(a,c)  B_tot
    C(b)    C_tot
end seed species

begin observables
    Molecules  A_free   A(b)
    Molecules  B_free   B(a,c)
    Molecules  C_free   C(b)
    Molecules  AB       A(b!1).B(a!1)
    Molecules  BC       B(c!1).C(b!1)
    Molecules  ABC      A(b!1).B(a!1,c!2).C(b!2)
end observables

begin reaction rules
    # A-B binding
    A(b) + B(a) <-> A(b!1).B(a!1)  kf1, kr1
    # B-C binding
    B(c) + C(b) <-> B(c!1).C(b!1)  kf2, kr2
    # A splits off from A-B-C complex: produces separate A + B.C
    A(b!1).B(a!1,c!+) -> A(b) + B(a,c!+)  k_split
end reaction rules
end model

begin actions
simulate({method=>"nf",t_end=>100,n_steps=>100})
end actions
