# Bivalent ligand - bivalent receptor
# No rings

begin parameters
 NA      6.0221e23 # (molecules/mol)
 f       0.10            # Fraction of the cell to simulate
 Vo      f*1.0e-11       # Extracellular volume=1/cell_density (L)
 V       f*3.0e-12       # Cytoplasmic volume (L)

# Initial populations.
 R0  1e4*f
 L0  1e4*f

# Rate constants
 kp1 2.3e7/(NA*V)
 km1 1
 kp2 2.3e10/(NA*V)
 km2 1

end parameters

begin molecule types
  R(r,r)
  L(l,l)
end molecule types

begin species
  R(r,r) R0
  L(l,l) L0
end species

begin reaction rules
# Ligand addition
R(r) + L(l,l) <-> R(r!1).L(l!1,l) kp1,km1

# Chain elongation
R(r) + L(l,l!+) <-> R(r!1).L(l!1,l!+) kp2,km2
end reaction rules

begin observables
Species Ligfree_1   L(l,l)
Species Ligbnd1_1   L(l!+,l)
Species Ligbnd2_1   L(l!+,l!+)
Species Size1_1   R()=1
Species Size2_1   R()=2
Species Size3_1   R()=3
Species Size4_1   R()=4
Species Size5_1   R()=5
Species Size6_1   R()=6
Species Size7_1   R()=7
Species Size8_1   R()=8
Species Size9_1   R()=9
Species Size10_1   R()=10
Species SizeGT10_1   R()>10
end observables

begin actions
simulate({method=>"nf",t_end=>10,n_steps=>100})
end actions
