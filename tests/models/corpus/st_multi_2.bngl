# State change reaction: multiple events at the same reaction step

begin parameters
t_end		10
n_steps         100
kf1		0.1
kb1		0.5
kf2		0.4
kb2		0.6
A_tot		10000
end parameters

begin molecule types
A(a~U~P,b~U~P,c~U~P)
end molecule types

begin species
A(a~U,b~U,c~U)		A_tot
end species

begin reaction rules
A(a~U,b~U) <-> A(a~P,b~P) kf1,kb1
A(c~U) <-> A(c~P) kf2,kb2
end reaction rules

begin observables
Species UUP_1   A(a~U,b~U,c~P)
Species PPU_1   A(a~P,b~P,c~U)
Species UUU_1   A(a~U,b~U,c~U)
Species PPP_1   A(a~P,b~P,c~P)
end observables

begin actions
simulate({method=>"nf",t_end=>10,n_steps=>100})
end actions
