# 5-valent ligand - 3-valent receptor
# No rings
# above phase transition

begin parameters
t_end		1000
n_steps		1000
Lig_n        4200
Rec_n        300
kp1        3.0e-7
km1        0.01
kp2        1.0e-4
km2        0.01
kp3        1.0e-4
km3        0.01
kp4        1.0e-4
km4        0.01
kp5        1.0e-4
km5        0.01
end parameters

begin species
 L(r,r,r,r,r) Lig_n
 R(l,l,l)   Rec_n
end species

begin reaction rules
L(r,r,r,r,r) + R(l) <-> L(r!1,r,r,r,r).R(l!1) kp1,km1
L(r,r,r,r,r!+) + R(l) <-> L(r!1,r,r,r,r!+).R(l!1) kp2,km2
L(r,r,r,r!+,r!+) + R(l) <-> L(r!1,r,r,r!+,r!+).R(l!1) kp3,km3
L(r,r,r!+,r!+,r!+) + R(l) <-> L(r!1,r,r!+,r!+,r!+).R(l!1) kp4,km4
L(r,r!+,r!+,r!+,r!+) + R(l) <-> L(r!1,r!+,r!+,r!+,r!+).R(l!1) kp5,km5
end reaction rules

