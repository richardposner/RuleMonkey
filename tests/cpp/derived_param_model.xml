<?xml version="1.0" encoding="UTF-8"?>
<!-- Hand-authored derived-parameter test fixture for set_param_test.cpp.
     Mirrors A_plus_A.xml semantics (A + A <-> AA dimerization) but
     re-expresses every numeric parameter as a derivation of base
     parameters so set_param overrides exercise the apply_overrides
     parameter cascade.

       A_base   = 100        (base)
       A_factor = 5          (base)
       A_tot    = A_base * A_factor  (= 500, derived; seed count for A)
       kp_base  = 0.0001     (base)
       kp_mult  = 10         (base)
       kp       = kp_base * kp_mult  (= 0.001, derived; bind rate)
       km       = 0.5        (base; unbind rate, not derived)
-->
<sbml xmlns="http://www.sbml.org/sbml/level3" level="3" version="1">
  <model id="derived_param_model">
    <ListOfParameters>
      <Parameter id="A_base"   type="Constant" value="100"      expr="100"/>
      <Parameter id="A_factor" type="Constant" value="5"        expr="5"/>
      <Parameter id="A_tot"    type="Constant" value="A_base*A_factor" expr="A_base*A_factor"/>
      <Parameter id="kp_base"  type="Constant" value="0.0001"   expr="0.0001"/>
      <Parameter id="kp_mult"  type="Constant" value="10"       expr="10"/>
      <Parameter id="kp"       type="Constant" value="kp_base*kp_mult" expr="kp_base*kp_mult"/>
      <Parameter id="km"       type="Constant" value="0.5"      expr="0.5"/>
    </ListOfParameters>
    <ListOfMoleculeTypes>
      <MoleculeType id="A">
        <ListOfComponentTypes>
          <ComponentType id="a"/>
        </ListOfComponentTypes>
      </MoleculeType>
    </ListOfMoleculeTypes>
    <ListOfCompartments>
    </ListOfCompartments>
    <ListOfSpecies>
      <Species id="S1" concentration="A_tot" name="A(a)">
        <ListOfMolecules>
          <Molecule id="S1_M1" name="A">
            <ListOfComponents>
              <Component id="S1_M1_C1" name="a" numberOfBonds="0"/>
            </ListOfComponents>
          </Molecule>
        </ListOfMolecules>
      </Species>
    </ListOfSpecies>
    <ListOfReactionRules>
      <ReactionRule id="RR1" name="_R1" symmetry_factor="0.5">
        <ListOfReactantPatterns>
          <ReactantPattern id="RR1_RP1">
            <ListOfMolecules>
              <Molecule id="RR1_RP1_M1" name="A">
                <ListOfComponents>
                  <Component id="RR1_RP1_M1_C1" name="a" numberOfBonds="0"/>
                </ListOfComponents>
              </Molecule>
            </ListOfMolecules>
          </ReactantPattern>
          <ReactantPattern id="RR1_RP2">
            <ListOfMolecules>
              <Molecule id="RR1_RP2_M1" name="A">
                <ListOfComponents>
                  <Component id="RR1_RP2_M1_C1" name="a" numberOfBonds="0"/>
                </ListOfComponents>
              </Molecule>
            </ListOfMolecules>
          </ReactantPattern>
        </ListOfReactantPatterns>
        <ListOfProductPatterns>
          <ProductPattern id="RR1_PP1">
            <ListOfMolecules>
              <Molecule id="RR1_PP1_M1" name="A">
                <ListOfComponents>
                  <Component id="RR1_PP1_M1_C1" name="a" numberOfBonds="1"/>
                </ListOfComponents>
              </Molecule>
              <Molecule id="RR1_PP1_M2" name="A">
                <ListOfComponents>
                  <Component id="RR1_PP1_M2_C1" name="a" numberOfBonds="1"/>
                </ListOfComponents>
              </Molecule>
            </ListOfMolecules>
            <ListOfBonds>
              <Bond id="RR1_PP1_B1" site1="RR1_PP1_M1_C1" site2="RR1_PP1_M2_C1"/>
            </ListOfBonds>
          </ProductPattern>
        </ListOfProductPatterns>
        <RateLaw id="RR1_RateLaw" type="Ele" totalrate="0">
          <ListOfRateConstants>
            <RateConstant value="kp"/>
          </ListOfRateConstants>
        </RateLaw>
        <Map>
          <MapItem sourceID="RR1_RP1_M1"    targetID="RR1_PP1_M1"/>
          <MapItem sourceID="RR1_RP1_M1_C1" targetID="RR1_PP1_M1_C1"/>
          <MapItem sourceID="RR1_RP2_M1"    targetID="RR1_PP1_M2"/>
          <MapItem sourceID="RR1_RP2_M1_C1" targetID="RR1_PP1_M2_C1"/>
        </Map>
        <ListOfOperations>
          <AddBond site1="RR1_RP1_M1_C1" site2="RR1_RP2_M1_C1"/>
        </ListOfOperations>
      </ReactionRule>
      <ReactionRule id="RR2" name="_reverse__R1" symmetry_factor="0.5">
        <ListOfReactantPatterns>
          <ReactantPattern id="RR2_RP1">
            <ListOfMolecules>
              <Molecule id="RR2_RP1_M1" name="A">
                <ListOfComponents>
                  <Component id="RR2_RP1_M1_C1" name="a" numberOfBonds="1"/>
                </ListOfComponents>
              </Molecule>
              <Molecule id="RR2_RP1_M2" name="A">
                <ListOfComponents>
                  <Component id="RR2_RP1_M2_C1" name="a" numberOfBonds="1"/>
                </ListOfComponents>
              </Molecule>
            </ListOfMolecules>
            <ListOfBonds>
              <Bond id="RR2_RP1_B1" site1="RR2_RP1_M1_C1" site2="RR2_RP1_M2_C1"/>
            </ListOfBonds>
          </ReactantPattern>
        </ListOfReactantPatterns>
        <ListOfProductPatterns>
          <ProductPattern id="RR2_PP1">
            <ListOfMolecules>
              <Molecule id="RR2_PP1_M1" name="A">
                <ListOfComponents>
                  <Component id="RR2_PP1_M1_C1" name="a" numberOfBonds="0"/>
                </ListOfComponents>
              </Molecule>
            </ListOfMolecules>
          </ProductPattern>
          <ProductPattern id="RR2_PP2">
            <ListOfMolecules>
              <Molecule id="RR2_PP2_M1" name="A">
                <ListOfComponents>
                  <Component id="RR2_PP2_M1_C1" name="a" numberOfBonds="0"/>
                </ListOfComponents>
              </Molecule>
            </ListOfMolecules>
          </ProductPattern>
        </ListOfProductPatterns>
        <RateLaw id="RR2_RateLaw" type="Ele" totalrate="0">
          <ListOfRateConstants>
            <RateConstant value="km"/>
          </ListOfRateConstants>
        </RateLaw>
        <Map>
          <MapItem sourceID="RR2_RP1_M1"    targetID="RR2_PP1_M1"/>
          <MapItem sourceID="RR2_RP1_M1_C1" targetID="RR2_PP1_M1_C1"/>
          <MapItem sourceID="RR2_RP1_M2"    targetID="RR2_PP2_M1"/>
          <MapItem sourceID="RR2_RP1_M2_C1" targetID="RR2_PP2_M1_C1"/>
        </Map>
        <ListOfOperations>
          <DeleteBond site1="RR2_RP1_M1_C1" site2="RR2_RP1_M2_C1"/>
        </ListOfOperations>
      </ReactionRule>
    </ListOfReactionRules>
    <ListOfObservables>
      <Observable id="O1" name="A_1" type="Species">
        <ListOfPatterns>
          <Pattern id="O1_P1" matchOnce="1">
            <ListOfMolecules>
              <Molecule id="O1_P1_M1" name="A">
                <ListOfComponents>
                  <Component id="O1_P1_M1_C1" name="a" numberOfBonds="0"/>
                </ListOfComponents>
              </Molecule>
            </ListOfMolecules>
          </Pattern>
        </ListOfPatterns>
      </Observable>
      <Observable id="O2" name="AA_1" type="Species">
        <ListOfPatterns>
          <Pattern id="O2_P1" matchOnce="1">
            <ListOfMolecules>
              <Molecule id="O2_P1_M1" name="A">
                <ListOfComponents>
                  <Component id="O2_P1_M1_C1" name="a" numberOfBonds="1"/>
                </ListOfComponents>
              </Molecule>
              <Molecule id="O2_P1_M2" name="A">
                <ListOfComponents>
                  <Component id="O2_P1_M2_C1" name="a" numberOfBonds="1"/>
                </ListOfComponents>
              </Molecule>
            </ListOfMolecules>
            <ListOfBonds>
              <Bond id="O2_P1_B1" site1="O2_P1_M1_C1" site2="O2_P1_M2_C1"/>
            </ListOfBonds>
          </Pattern>
        </ListOfPatterns>
      </Observable>
    </ListOfObservables>
    <ListOfFunctions>
    </ListOfFunctions>
  </model>
</sbml>
